      />

      <style>{`
        @media (max-width: 500px) {
          .hero-header { padding: 44px 16px 36px !important; }
          .games-grid { gap: 10px !important; padding: 0 8px 80px !important; }
          .game-card { border-radius: 16px !important; }
        }
      `}</style>
    </main>
