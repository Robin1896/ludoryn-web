// ─────────────────────────────────────────────
// GameTile
// ─────────────────────────────────────────────

function GameTile({ game, index }: { game: (typeof GAMES)[number]; index: number }) {
  const [hovered, setHovered] = useState(false);
  const { t } = useLang();
  const artFn = GAME_ART[game.id];

  // Dynamic translated fields for known games
  const translated = {
    subtitle: game.id === 'grub' ? t.grubSubtitle
      : game.id === 'qwixx' ? t.kriskrasSubtitle
      : game.id === 'ticket-to-ride' ? t.ttrSubtitle
      : game.id === 'beverbende' ? t.beaverSubtitle
      : game.id === 'placeholder' ? t.comingSoon
      : game.subtitle,
    description: game.id === 'grub' ? t.grubDesc
      : game.id === 'qwixx' ? t.kriskrasDesc
      : game.id === 'ticket-to-ride' ? t.ttrDesc
      : game.id === 'beverbende' ? t.beaverDesc
      : game.id === 'placeholder' ? t.moreComing
      : game.description,
    players: game.id === 'grub' ? t.grubPlayers
      : game.id === 'qwixx' ? t.kriskrasPlayers
      : game.id === 'ticket-to-ride' ? t.ttrPlayers
      : game.id === 'beverbende' ? t.beaverPlayers
      : game.players,
    title: game.id === 'placeholder' ? t.moreGames : game.title,
  };

  const card = (
    <div
      className="game-card"
      onMouseEnter={() => setHovered(true)}
      onMouseLeave={() => setHovered(false)}
      style={{
        background: game.available
          ? `linear-gradient(145deg, ${game.accent}28 0%, ${game.accent}08 60%, var(--card) 100%)`
          : "var(--card2)",
        border: `1.5px solid ${hovered && game.available ? game.accent + "88" : game.available ? game.accent + "45" : "rgba(255,255,255,0.08)"}`,
        borderRadius: 18,
        overflow: "hidden",
        transition: "box-shadow 0.2s, border-color 0.2s, transform 0.2s",
        animation: `slide-up 0.35s ease ${index * 60}ms both`,
        boxShadow: hovered && game.available
          ? `0 0 32px ${game.accent}44, 0 8px 24px rgba(0,0,0,0.4)`
          : game.available ? `0 2px 12px ${game.accent}18` : "0 2px 8px rgba(0,0,0,0.2)",
        transform: hovered && game.available ? "translateY(-3px)" : "none",
        cursor: game.available ? "pointer" : "default",
        opacity: game.available ? 1 : 0.2,
        filter: game.available ? "none" : "blur(4px)",
        pointerEvents: game.available ? "auto" : "none",
        display: "flex",
        flexDirection: "row",
        alignItems: "stretch",
        height: 100,
      }}
    >
      {/* Art thumbnail — fills the left side of the card */}
      <div style={{ width: 100, flexShrink: 0, overflow: "hidden" }}>
        {artFn ? artFn({ uid: game.id + "-tile" }) : null}
      </div>

      {/* Thin accent line between art and text */}
      <div style={{ width: 2, flexShrink: 0, background: `${game.accent}30` }} />

      {/* Text content */}
      <div style={{ flex: 1, padding: "12px 14px", minWidth: 0, display: "flex", flexDirection: "column", justifyContent: "center" }}>
        <div style={{ fontFamily: "'Fredoka', sans-serif", fontSize: 20, fontWeight: 700, color: "var(--text)", lineHeight: 1.15, whiteSpace: "nowrap", overflow: "hidden", textOverflow: "ellipsis" }}>
          {translated.title}
        </div>
        <div style={{ fontFamily: "'Nunito', sans-serif", fontSize: 10, fontWeight: 800, letterSpacing: "0.14em", textTransform: "uppercase", color: game.available ? game.accent : "rgba(238,242,255,0.28)", marginTop: 2, whiteSpace: "nowrap", overflow: "hidden", textOverflow: "ellipsis" }}>
          {translated.subtitle}
        </div>
        <p style={{ fontFamily: "'Nunito', sans-serif", fontSize: 12, color: "var(--text-muted)", lineHeight: 1.45, margin: "5px 0 0", overflow: "hidden", display: "-webkit-box", WebkitLineClamp: 2, WebkitBoxOrient: "vertical" }}>
          {translated.description}
        </p>
      </div>

      {/* Round play button */}
      <div style={{ flexShrink: 0, display: "flex", alignItems: "center", paddingRight: 16, paddingLeft: 8 }}>
        {game.available ? (
          <div style={{
            width: 44, height: 44, borderRadius: "50%",
            background: game.accent,
            boxShadow: `0 0 14px ${game.accent}66, 0 3px 0 ${game.shadow}`,
            display: "flex", alignItems: "center", justifyContent: "center",
            fontSize: 14, color: "#fff",
            transition: "transform 0.15s",
            transform: hovered ? "scale(1.1)" : "scale(1)",
            flexShrink: 0,
          }}>
            ▶
          </div>
        ) : (
          <div style={{
            width: 44, height: 44, borderRadius: "50%",
            border: "1px solid rgba(255,255,255,0.1)",
            display: "flex", alignItems: "center", justifyContent: "center",
            fontSize: 14, color: "rgba(238,242,255,0.2)",
            flexShrink: 0,
          }}>
            ⏳
          </div>
        )}
      </div>
    </div>
  );

  return game.available ? (
    <Link href={game.href} style={{ textDecoration: "none", color: "inherit" }} onClick={playClick}>{card}</Link>
  ) : card;
}

// ─────────────────────────────────────────────
// Page
// ─────────────────────────────────────────────

export default function HomePage() {
  const router = useRouter();
  const { t } = useLang();
  useEffect(() => { window.scrollTo(0, 0); }, []);
  return (
    <main style={{ minHeight: "100vh", background: "var(--bg-gradient)", color: "var(--text)" }}>
      <LangToggle />

      {/* Hero */}
      <header className="hero-header" style={{ textAlign: "center", padding: "88px 24px 72px", position: "relative", overflow: "hidden", WebkitMaskImage: "linear-gradient(to bottom, black 50%, transparent 100%)", maskImage: "linear-gradient(to bottom, black 50%, transparent 100%)" }}>
        {/* Atmospheric glow orbs */}
        <div aria-hidden style={{ position: "absolute", inset: 0, pointerEvents: "none" }}>
          <div style={{ position: "absolute", top: "-5%", left: "-5%", width: 500, height: 500, borderRadius: "50%", background: "radial-gradient(circle, rgba(66,133,244,0.28) 0%, transparent 65%)" }} />
          <div style={{ position: "absolute", top: "-2%", right: "-5%", width: 420, height: 420, borderRadius: "50%", background: "radial-gradient(circle, rgba(171,71,188,0.32) 0%, transparent 65%)" }} />
          <div style={{ position: "absolute", bottom: "-15%", left: "20%", width: 600, height: 400, borderRadius: "50%", background: "radial-gradient(circle, rgba(0,200,117,0.18) 0%, transparent 65%)" }} />
          <div style={{ position: "absolute", bottom: "10%", right: "-10%", width: 350, height: 350, borderRadius: "50%", background: "radial-gradient(circle, rgba(255,202,40,0.15) 0%, transparent 65%)" }} />
          {/* Floating decorative dice */}
          <svg aria-hidden style={{ position: "absolute", top: "12%", left: "12%", opacity: 0.18, animation: "float 5s ease-in-out infinite" }} width="40" height="40" viewBox="0 0 40 40">
            <rect width="40" height="40" rx="8" fill="#4285F4" transform="rotate(18 20 20)" />
            <circle cx="13" cy="13" r="3.5" fill="#080B24" transform="rotate(18 20 20)" />
            <circle cx="27" cy="27" r="3.5" fill="#080B24" transform="rotate(18 20 20)" />
          </svg>
          <svg aria-hidden style={{ position: "absolute", top: "20%", right: "14%", opacity: 0.14, animation: "float 7s ease-in-out 1s infinite" }} width="50" height="50" viewBox="0 0 50 50">
            <polygon points="25,2 47,13.5 47,36.5 25,48 3,36.5 3,13.5" fill="#FF5252" />
          </svg>
          <svg aria-hidden style={{ position: "absolute", bottom: "18%", left: "18%", opacity: 0.12, animation: "float 6s ease-in-out 2s infinite" }} width="36" height="36" viewBox="0 0 36 36">
            <rect width="36" height="36" rx="7" fill="#FFCA28" transform="rotate(-12 18 18)" />
            <circle cx="11" cy="11" r="3" fill="#080B24" transform="rotate(-12 18 18)" />
            <circle cx="25" cy="25" r="3" fill="#080B24" transform="rotate(-12 18 18)" />
            <circle cx="18" cy="18" r="3" fill="#080B24" transform="rotate(-12 18 18)" />
          </svg>
          <svg aria-hidden style={{ position: "absolute", bottom: "22%", right: "16%", opacity: 0.15, animation: "float 8s ease-in-out 0.5s infinite" }} width="44" height="44" viewBox="0 0 44 44">
            <polygon points="22,1 43,12 43,32 22,43 1,32 1,12" fill="#00C875" />
          </svg>
        </div>

        <h1
          style={{
            fontFamily: "'Fredoka', sans-serif",
            fontWeight: 700,
            fontSize: "clamp(72px, 16vw, 160px)",
            margin: 0,
            lineHeight: 0.9,
            background: "linear-gradient(160deg, #ffffff 0%, #BF5AF2 60%, #7C3AED 100%)",
            WebkitBackgroundClip: "text",
            WebkitTextFillColor: "transparent",
            backgroundClip: "text",
            position: "relative",
            animation: "scale-in 0.6s cubic-bezier(0.34,1.56,0.64,1) both",
          }}
        >
          LUDORYN
        </h1>
        <p
          style={{
            fontFamily: "'Nunito', sans-serif",
            fontSize: 13,
            fontWeight: 800,
            letterSpacing: "0.32em",
            textTransform: "uppercase",
            color: "var(--text-muted)",
            margin: "24px 0 0",
            position: "relative",
            animation: "fade-in 0.8s ease 0.3s both",
          }}
        >
          {t.tagline}
        </p>

      </header>


      {/* Resume banner */}
      <ResumeGameBanner />

      {/* Game grid */}
      <section style={{ maxWidth: 1100, margin: "0 auto", padding: "0 12px 100px" }}>
        <div
          className="games-grid"
          style={{
            display: "flex",
