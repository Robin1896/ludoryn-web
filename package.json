{
  "name": "ludus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "build": "next build",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "build:cap": "CAPACITOR_BUILD=1 next build && npx cap copy",
    "cap:ios": "npm run build:cap && npx cap open ios",
    "cap:android": "npm run build:cap && npx cap open android",
    "cap:icons": "npx @capacitor/assets generate"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@revenuecat/purchases-capacitor": "^12.3.0",
    "@upstash/redis": "^1.38.0",
    "gsap": "^3.14.2",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "pusher": "^5.3.3",
    "pusher-js": "^8.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
